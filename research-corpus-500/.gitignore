# Exclude the image files — they're regenerable from the seeds in manifest.json.
qf*/
# Exclude stego products that may be generated alongside the covers.
stego/
# Exclude locally-generated payload binaries (regenerated by embed_multipass.sh).
scripts/payload_*.bin
scripts/payload_*.bin.sha256
# But keep the manifest and README
!manifest.json
!README.md
